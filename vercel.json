{
  "projectSettings": {
    "nodeVersion": "20.x"
  },
  "buildCommand": "node scripts/setup-env.js && npm run build",
  "outputDirectory": "dist/cosmeticos-artesanais",
  "env": {
    "SUPABASE_URL": {
      "description": "URL do seu projeto Supabase (ex: https://xxxx.supabase.co)"
    },
    "SUPABASE_ANON_KEY": {
      "description": "Chave pública (anon) do Supabase"
    },
    "MP_PUBLIC_KEY": {
      "description": "Chave pública do Mercado Pago"
    }
  }
}
